# ============================================================
#  Secure API System — Environment Configuration
#  Copy this file to .env and fill in your real values
# ============================================================

# --- MongoDB Atlas -----------------------------------------------------------
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/secure_api_system?retryWrites=true&w=majority&appName=Cluster0

# --- JWT Secrets (use a strong random string in production) ------------------
JWT_SECRET=CHANGE_ME_run_openssl_rand_-hex_32
JWT_ALGORITHM=HS256
ACCESS_EXPIRE=30
REFRESH_EXPIRE=7

# --- Redis (Upstash free tier works great for production) --------------------
# Local:  redis://localhost:6379
# Upstash: redis://:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379

# --- Rate Limiting -----------------------------------------------------------
RATE_LIMIT_MAX=60
BLOCK_THRESHOLD=5

# --- CORS (comma-separated list of allowed origins) --------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- App Meta ----------------------------------------------------------------
APP_ENV=development
APP_VERSION=2.0.0
